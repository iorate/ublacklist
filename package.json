{
  "name": "ublacklist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#builtin/*": "./builtin/*"
  },
  "scripts": {
    "build": "node scripts/build.ts",
    "check": "pnpm run /^check:/",
    "check:biome": "biome check",
    "check:prettier": "prettier --check \"**/*.{md,yaml,yml}\"",
    "check:typescript": "tsgo",
    "fix": "pnpm run /^fix:/",
    "fix:biome": "biome check --write",
    "fix:prettier": "prettier --write \"**/*.{md,yaml,yml}\"",
    "generate": "pnpm run /^generate:/",
    "generate:message-names": "node scripts/generate-message-names.ts",
    "test": "node --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@lezer/highlight": "^1.2.3",
    "@mdi/svg": "^7.4.47",
    "@neodrag/vanilla": "^2.3.1",
    "@sindresorhus/fnv1a": "^3.1.0",
    "@ublacklist/match-pattern": "^1.2.0",
    "@ublacklist/ruleset": "^1.0.2",
    "@ublacklist/serpinfo": "^1.1.0",
    "colord": "^2.9.3",
    "css-tree": "^3.2.1",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.46.1",
    "goober": "2.1.15",
    "is-mobile": "^5.0.0",
    "lz-string": "^1.5.0",
    "punycode": "^2.3.1",
    "react": "^19.2.6",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.6",
    "tldts": "^7.0.30",
    "webdav": "^5.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/css-tree": "^2.3.11",
    "@types/fs-extra": "^11.0.4",
    "@types/license-checker": "^25.0.6",
    "@types/node": "^24.12.3",
    "@types/punycode": "^2.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "csstype": "^3.2.3",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "fs-extra": "^11.3.5",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3"
  },
  "packageManager": "pnpm@11.1.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "download"
    }
  }
}
