{
  "name": "ublacklist",
  "version": "10.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#builtin/*": "./builtin/*"
  },
  "scripts": {
    "build": "node scripts/build.ts",
    "check": "pnpm run /^check:/",
    "check:biome": "biome check",
    "check:prettier": "prettier --check \"**/*.{md,yaml,yml}\"",
    "check:typescript": "tsc",
    "e2e": "pnpm build --e2e && playwright test --config e2e/playwright.config.ts",
    "fix": "pnpm run /^fix:/",
    "fix:biome": "biome check --write",
    "fix:prettier": "prettier --write \"**/*.{md,yaml,yml}\"",
    "generate": "pnpm run /^generate:/",
    "generate:message-names": "node scripts/generate-message-names.ts",
    "test": "node --test"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-yaml": "6.1.3",
    "@codemirror/language": "6.12.4",
    "@codemirror/lint": "6.9.7",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@lezer/highlight": "1.2.3",
    "@mdi/svg": "7.4.47",
    "@neodrag/vanilla": "2.3.1",
    "@sindresorhus/fnv1a": "3.1.0",
    "@ublacklist/match-pattern": "1.2.0",
    "@ublacklist/ruleset": "1.0.3",
    "@ublacklist/serpinfo": "1.1.1",
    "clsx": "2.1.1",
    "colord": "2.9.3",
    "css-tree": "3.2.1",
    "dayjs": "1.11.21",
    "es-toolkit": "1.49.0",
    "is-mobile": "5.0.0",
    "lz-string": "1.5.0",
    "punycode": "2.3.1",
    "react": "19.2.7",
    "react-colorful": "5.8.0",
    "react-dom": "19.2.7",
    "tldts": "7.4.8",
    "webdav": "5.10.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@types/css-tree": "2.3.11",
    "@types/fs-extra": "11.0.4",
    "@types/license-checker": "25.0.6",
    "@types/node": "24.13.3",
    "@types/punycode": "2.1.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/webextension-polyfill": "0.12.5",
    "chrome-types": "0.1.434",
    "csstype": "3.2.3",
    "dotenv": "17.4.2",
    "esbuild": "0.28.1",
    "fs-extra": "11.3.6",
    "lefthook": "2.1.10",
    "prettier": "3.9.5",
    "typescript": "7.0.2"
  },
  "packageManager": "pnpm@11.15.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  }
}
